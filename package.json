{
  "name": "dt-workbench-monorepo",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "deploy:web": "echo 'Deploying via GitHub CD. Check Cloud Build in GCP Console: https://console.cloud.google.com/cloud-build/builds'",
    "deploy:web:local": "gcloud run deploy dt-workbench-web --source . --region europe-west9 --allow-unauthenticated"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.0.0"
  }
}
