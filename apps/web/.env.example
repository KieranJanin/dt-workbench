# GCP Cloud SQL (PostgreSQL)
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[IP]:[PORT]/[DB_NAME]"

# Neo4j Aura (Graph)
NEO4J_URI="neo4j+s://[INSTANCE_ID].databases.neo4j.io"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your-neo4j-password"

# Vertex AI (Vector Search & LLM)
GOOGLE_APPLICATION_CREDENTIALS="/path/to/your/gcp-service-account.json"
VERTEX_AI_PROJECT_ID="your-gcp-project-id"
VERTEX_AI_LOCATION="europe-west9"

# GCP Cloud Storage (Optional for web, used by Companion)
GCP_STORAGE_BUCKET="dt-workbench-assets"

# MCP Integrations (Track 5)
NOTION_API_TOKEN="your-notion-internal-integration-token"
MIRO_API_TOKEN="your-miro-api-token"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REFRESH_TOKEN="your-google-refresh-token"
